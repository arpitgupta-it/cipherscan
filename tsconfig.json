{
    "compilerOptions": {
        "outDir": "./out",
        "target": "es5",
        "downlevelIteration": true,
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": [
            "node",
            "fs-extra"
        ]
    },
    "include": [
        "src/**/*.ts"
    ]
}