{
    "name": "cipherscan",
    "displayName": "CipherScan",
    "description": "Scan for exposed secrets in your code",
    "version": "1.0.0",
    "icon": "img/icon128.png",
    "author": "Arpit Gupta",
    "publisher": "arpitgupta-it",
    "engines": {
        "vscode": "^1.77.0"
    },
    "main": "./out/main.js",
    "activationEvents": [
        "onStartupFinished"
    ],
    "contributes": {
        "configuration": {
            "properties": {
                "cipherscan.customPatterns": {
                    "type": "array",
                    "default": [],
                    "description": "Custom patterns for detecting secrets.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "Name of the pattern."
                            },
                            "regex": {
                                "type": "string",
                                "description": "Regex for detecting the secret.",
                                "pattern": "^(?!\\s*$).+",
                                "errorMessage": "Regex pattern must not be empty."
                            }
                        },
                        "additionalProperties": false
                    }
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "lint": "eslint src/**/*.ts"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^22.9.1",
        "@types/vscode": "^1.77.0",
        "typescript": "^4.4.3",
        "vsce": "^1.89.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/arpitgupta-it/cipherscan.git"
    },
    "license": "Apache-2.0",
    "dependencies": {
        "fs-extra": "^11.2.0"
    }
}